{
  "poll_interval_seconds": 300,
  "price_interval_seconds": 86400,
  "db_path": "data/tracker.db",

  "alerts": {
    "desktop": true,
    "discord_webhook": ""
  },

  "_comment_ingest": "Local push endpoint for the browser extension. Binds 127.0.0.1 only. token auto-generates into data/ingest_token.txt on first run.",
  "ingest": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8765,
    "token": "",
    "allowed_origin": "",
    "record_price_points": true,
    "extension_stores": ["argos", "smyths", "very", "john_lewis", "game"]
  },

  "_comment_ebay": "eBay UK last-sold scraped SERVER-SIDE (tracker/prices/ebay.py). Auto-enabled for any watchlist item with an ebay_query.",
  "ebay": {
    "enabled": true,
    "max_samples": 15,
    "ipg": 60
  },

  "_comment_ebay_bin": "Cheapest active Buy-It-Now listing per product (with buy URL). Refreshed in a STAGGERED rolling loop: `batch` products per monitor cycle. At batch=2 over a 5-min poll, all ~73 refresh about every 3 hours (~0.5 req/min, very gentle on eBay). Shares the warmed cookie jar with ebay_sold. Bump batch to 6 for ~hourly.",
  "ebay_bin": {
    "enabled": true,
    "ipg": 60,
    "batch": 2,
    "delay_seconds": 6,
    "jitter_seconds": 6,
    "cookie_path": "data/ebay_cookies.pkl"
  },

  "stores": {
    "mock": { "adapter": "mock" },

    "totalcards":   { "adapter": "shopify" },
    "365games":     { "adapter": "shopify" },

    "chaoscards":    { "adapter": "jsonld" },
    "magicmadhouse": { "adapter": "jsonld" },

    "_comment_awin": "Blocked to direct scraping. Awin datafeed route (see README); flip enabled:true + add feed_url when approved.",
    "argos":      { "adapter": "awin", "enabled": false, "feed_url": "", "id_regex": "/product/(\\d+)" },
    "smyths":     { "adapter": "awin", "enabled": false, "feed_url": "", "id_regex": "/p/(\\d+)" },
    "very":       { "adapter": "awin", "enabled": false, "feed_url": "", "id_regex": "/(\\d+)\\.prd" },
    "john_lewis": { "adapter": "awin", "enabled": false, "feed_url": "", "id_regex": "/p(\\d+)" },
    "game":       { "adapter": "awin", "enabled": false, "feed_url": "", "id_regex": "-(\\d+)(?:$|\\?)" },

    "pokemoncenter_uk": { "adapter": "jsonld", "enabled": false },
    "amazon_uk":        { "adapter": "jsonld", "enabled": false }
  },

  "price_sources": {
    "mock": { "adapter": "mock" },
    "pricecharting": { "adapter": "pricecharting" },
    "ebay_sold": { "adapter": "ebay_sold", "ipg": 60, "max_samples": 15, "delay_seconds": 8, "jitter_seconds": 8, "cookie_path": "data/ebay_cookies.pkl" }
  },

