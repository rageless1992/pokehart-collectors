# PokeHart Collectors — secrets template.
#
# This .example file is safe to commit. The REAL file (secrets.toml) is gitignored.
#
# • On Streamlit Community Cloud: set this in the app's  Settings → Secrets  box.
# • To test the password locally: copy this file to ".streamlit/secrets.toml" and
#   fill in a password. (With no secret set, the app runs open with no password.)

app_password = "choose-a-family-password"
